                <h2 style='color: white; margin: 10px 0 0 0;'>It's Finally Here!</h2>
            </div>
            
            <!-- Body -->
            <div style='padding: 40px 30px;'>
                <p style='font-size: 16px; line-height: 1.6; color: #333;'>
                    You asked to be notified when our iOS app launched – and <strong>it's LIVE right now!</strong>
                </p>
                
                <p style='font-size: 16px; line-height: 1.6; color: #333;'>
                    Download the <strong>HostingAura Speed Test</strong> app and get access to premium features:
                </p>
                
                <ul style='font-size: 16px; line-height: 1.8; color: #333;'>
                    <li>📱 <strong>Push Notifications</strong> for test reminders</li>
                    <li>⏰ <strong>Scheduled Tests</strong> that run automatically</li>
                    <li>🔐 <strong>Face ID / Touch ID</strong> for quick login</li>
                    <li>⚡ <strong>Native iOS Performance</strong></li>
                </ul>
                
                <!-- Download Button -->
                <div style='text-align: center; margin: 30px 0;'>
                    <a href='$app_store_url' style='display: inline-block; background: linear-gradient(135deg, #6366f1, #8b5cf6); color: white; padding: 16px 40px; text-decoration: none; border-radius: 8px; font-weight: 600; font-size: 18px;'>
                        Download Now
                    </a>
                </div>
                
                <p style='font-size: 14px; line-height: 1.6; color: #666; text-align: center;'>
                    Or copy this link: <a href='$app_store_url' style='color: #6366f1;'>$app_store_url</a>
                </p>
                
                <hr style='border: none; border-top: 1px solid #eee; margin: 30px 0;'>
                
                <p style='font-size: 14px; line-height: 1.6; color: #666;'>
                    Thank you for your patience! Be one of the first to leave a review and let us know what you think.
                </p>
                
                <p style='font-size: 14px; line-height: 1.6; color: #666; margin-bottom: 0;'>
                    <strong>- The HostingAura Team</strong>
                </p>
            </div>
            
            <!-- Footer -->
            <div style='background: #f5f5f5; padding: 20px; text-align: center; font-size: 12px; color: #999;'>
                <p style='margin: 0 0 10px 0;'>
                    You received this email because you signed up for iOS app launch notifications at speed.hostingaura.com
                </p>
                <p style='margin: 0;'>
                    © " . date('Y') . " HostingAura. All rights reserved.<br>
                    <a href='https://hostingaura.com' style='color: #6366f1; text-decoration: none;'>hostingaura.com</a>
                </p>
            </div>
        </div>
    </body>
    </html>
    ";
    
    // Email headers
    $headers = [
        'From: ' . $from_email,
        'Reply-To: ' . $reply_to,
        'MIME-Version: 1.0',
        'Content-Type: text/html; charset=UTF-8'
    ];
    
    // Send email
    if (mail($email, $subject, $message, implode("\r\n", $headers))) {
        $sent_count++;
        
        // Mark as notified
        $stmt = $db->prepare("UPDATE app_launch_notifications SET notified = TRUE, notified_at = NOW() WHERE email = ?");
        $stmt->bind_param("s", $email);
        $stmt->execute();
        $stmt->close();
    } else {
        $failed_count++;
        $errors[] = $email;
    }
    
    // Small delay to avoid overwhelming mail server
    usleep(100000); // 0.1 second
}

$db->close();

