// ═══════════════════════════════════════════════════════════════
// SEND EMAILS
// ═══════════════════════════════════════════════════════════════

$db = getDBConnection();

// Get all users who haven't been notified
$stmt = $db->query("SELECT * FROM app_launch_notifications WHERE notified = FALSE");
$signups = $stmt->fetch_all(MYSQLI_ASSOC);

if (empty($signups)) {
    echo "<h1>✅ All Done!</h1>";
    echo "<p>No pending notifications. Everyone has already been notified.</p>";
    echo '<a href="admin-app-launch-signups.php">← Back to Admin</a>';
    exit;
}

$sent_count = 0;
$failed_count = 0;
$errors = [];

foreach ($signups as $signup) {
    $email = $signup['email'];
    
    // Email subject
    $subject = '🎉 HostingAura iOS App is LIVE!';
    
    // Email body (HTML)
    $message = "
    <!DOCTYPE html>
    <html>
    <head>
        <meta charset='UTF-8'>
